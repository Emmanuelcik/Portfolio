---
import { getCollection } from "astro:content";
import { useTranslations } from "~/i18n/utils";
import type { Lang } from "~/i18n/ui";
import ProjectCard from "~/components/ui/ProjectCard.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const entries = (await getCollection("projects")).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  const dateDiff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  if (dateDiff !== 0) return dateDiff;
  return a.data.order - b.data.order;
});
---

<section id="projects" class="projects">
  <div class="container">
    <header class="head reveal">
      <h2 class="title">
        <span class="gradient-text">{t("projects.title")}</span>
      </h2>
      <p class="intro">{t("projects.intro")}</p>
    </header>

    {
      entries.length === 0 ? (
        <p class="empty">{t("projects.empty")}</p>
      ) : (
        <div class="grid">
          {entries.map((entry, i) => (
            <ProjectCard entry={entry} lang={lang} index={i} />
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .projects {
    padding-block: var(--space-16);
  }

  .head {
    margin-bottom: var(--space-10);
  }

  .title {
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-3);
  }

  .intro {
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .projects {
      padding-block: var(--space-24);
    }

    .head {
      margin-bottom: var(--space-12);
    }

    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-8);
    }
  }
</style>
