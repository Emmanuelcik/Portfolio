---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getLangFromUrl, localizedPath, useTranslations } from "~/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={`404  ${t("404.title")}`}
  description={t("404.body")}
  noindex
>
  <section class="section container">
    <p class="error-code gradient-text">404</p>
    <h1>{t("404.title")}</h1>
    <p class="lede">{t("404.body")}</p>
    <a class="back-link" href={localizedPath("/", lang)}>{t("404.cta")}</a>
  </section>

  <style>
    .error-code {
      font-family: var(--font-mono);
      font-size: var(--text-5xl);
      font-weight: var(--weight-bold);
      letter-spacing: var(--tracking-tight);
      margin-bottom: var(--space-2);
    }

    .lede {
      max-width: 40ch;
      margin: var(--space-4) 0 var(--space-8);
      color: var(--color-text-muted);
      font-size: var(--text-lg);
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-6);
      border-radius: var(--radius-pill);
      background: var(--gradient-primary);
      color: var(--color-text-strong);
      font-weight: var(--weight-medium);
      transition: transform var(--duration-fast) var(--ease-out-quart);
    }

    .back-link:hover {
      transform: translateY(-2px);
    }
  </style>
</BaseLayout>
