---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProjectDetail from '~/components/sections/ProjectDetail.astro';
import { SITE_OWNER } from '~/data/socials';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => {
    const slug = entry.id.replace(/^\d+-/, '');
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

interface Props {
  entry: CollectionEntry<'projects'>;
  slug: string;
}

const { entry, slug } = Astro.props;
const { title, summary } = entry.data;
const pageTitle = `${title} · ${SITE_OWNER.shortName}`;
---

<BaseLayout title={pageTitle} description={summary.es}>
  <ProjectDetail entry={entry} slug={slug} lang="es" />
</BaseLayout>
